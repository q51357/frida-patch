From: Frida Patcher <patch@frida.re>
Date: Thu, 26 Dec 2025 12:00:00 +0000
Subject: [PATCH 1/4] Disable thread suspension on iOS 14 for Taurine compatibility

Thread suspension triggers kernel panics on iOS 14.7.1 with Taurine jailbreak.
This patch detects iOS 14 (Darwin 20.x) and disables thread suspension to
prevent system reboots when using Frida.

Related issue: iOS device reboots when running frida -Ua or frida-ps commands
on Taurine-jailbroken devices.

---
 subprojects/frida-gum/gum/gummemory.c | 26 +++++++++++++++++++++++++-
 1 file changed, 25 insertions(+), 1 deletion(-)

diff --git a/subprojects/frida-gum/gum/gummemory.c b/subprojects/frida-gum/gum/gummemory.c
index 1234567..abcdefg 100644
--- a/subprojects/frida-gum/gum/gummemory.c
+++ b/subprojects/frida-gum/gum/gummemory.c
@@ -18,6 +18,9 @@
 # include <ptrauth.h>
 #endif
 #include <stdlib.h>
 #include <string.h>
+#ifdef HAVE_DARWIN
+# include <sys/utsname.h>
+#endif

 #ifdef HAVE_ANDROID
 # include "gum/gumandroid.h"
@@ -495,9 +498,30 @@ gum_memory_patch_code (gpointer address,
   {
     GumPageProtection protection;
     GumSuspendOperation suspend_op = { 0, };
+    gboolean should_suspend_threads = FALSE;

     protection = rwx_supported ? GUM_PAGE_RWX : GUM_PAGE_RW;

+#if defined (HAVE_IOS) || defined (HAVE_TVOS)
+    /*
+     * PATCH: Disable thread suspension on iOS 14 for Taurine compatibility.
+     * Thread suspension triggers kernel panics on Taurine-based jailbreaks.
+     * iOS 14.x runs on Darwin 20.x kernel.
+     */
+    if (!rwx_supported)
+    {
+      static gboolean ios14_compat_mode = FALSE;
+      static gsize check_done = 0;
+
+      if (g_once_init_enter (&check_done))
+      {
+        struct utsname u;
+        ios14_compat_mode = (uname (&u) == 0 && strncmp (u.release, "20.", 3) == 0);
+        g_once_init_leave (&check_done, 1);
+      }
+      should_suspend_threads = !ios14_compat_mode;
+    }
+#else
     if (!rwx_supported)
+      should_suspend_threads = TRUE;
+#endif
+
+    if (should_suspend_threads)
     {
       gum_metal_array_init (&suspend_op.suspended_threads,
           sizeof (GumThreadId));
@@ -585,7 +609,7 @@ gum_memory_patch_code (gpointer address,
     }

 resume_threads:
-    if (!rwx_supported)
+    if (should_suspend_threads)
     {
       guint num_suspended, i;

--
